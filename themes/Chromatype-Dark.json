{
	"name": "Chromatype",
	"colors": {
		"editor.background": "#2d2d2dff",
		"editor.foreground": "#eeeeeeff",
		"activityBarBadge.background": "#eeeeeeff",
		"activityBarBadge.foreground": "#2d2d2dff",
		"sideBarTitle.foreground": "#bbbbbb"
	},
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"selfTypeKeyword": {
			"foreground": "#ff4a4a",
			"fontStyle": "normal"
		},
		"selfKeyword": {
			"foreground": "#ff4a4a",
			"fontStyle": "normal"
		},
		"macro": "#eeeeeeaa",
		"function.static": {
			"fontStyle": "underline"
		},
		"decorator": "#e0ce00ff",
		"generic": {
			"fontStyle": "italic"
		},
		"builtinAttribute": "#e0ce00ff",
		"attributeBracket": "#eeeeeeaa"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#eeeeee55"
			}
		},
		{
			"name": "Operators",
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#eeeeee88"
			}
		},
		{
			"name": "Keywords & Storage",
			"scope": [
				"keyword",
				"storage",
				"keyword.operator.new",
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#c645daff"
			}
		},
		{
			"name": "Modifiers",
			"scope": [
				"storage.modifier"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Important Keywords",
			"scope": [
				"keyword.other",
				"keyword.declaration",
				"keyword.operator.new"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#36d428"
			}
		},
		{
			"name": "Literals",
			"scope": [
				"constant.numeric",
				"constant.language.boolean"
			],
			"settings": {
				"foreground": "#e0ce00ff"
			}
		},
		{
			"name": "Functions",
			"scope": [
				"entity.name.function"
			],
			"settings": {
				"foreground": "#5ba2ff"
			}
		},
		{
			"name": "Types",
			"scope": [
				"entity.name.type"
			],
			"settings": {
				"foreground": "#ff9900"
			}
		},
		{
			"name": "Generic Parameters",
			"scope": [
				"entity.name.type.parameter"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "Traits",
			"scope": [
				"entity.name.type.trait"
			],
			"settings": {
				"foreground": "#5be6ff"
			}
		},
		{
			"name": "The Self",
			"scope": [
				"variable.language.self"
			],
			"settings": {
				"foreground": "#ff4a4a"
			}
		},
		{
			"name": "Super Special",
			"scope": [
				"entity.name.type.result.rust",
				"entity.name.type.option.rust"
			],
			"settings": {
				"foreground": "#ff4a4a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Super Special Types",
			"scope": [
				"entity.name.type.numeric"
			],
			"settings": {
				"foreground": "#ff4a4a",
				"fontStyle": "underline"
			}
		},
		{
			"name": "Macros",
			"scope": [
				"entity.name.function.macro.rules.rust",
				"variable.other.metavariable.specifier.rust"
			],
			"settings": {
				"foreground": "#eeeeeeaa"
			}
		},
		{
			"name": "Constants",
			"scope": [
				"constant.other.caps"
			],
			"settings": {
				"foreground": "#ff4a4a"
			}
		}
	]
}